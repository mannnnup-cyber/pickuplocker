# Database (PostgreSQL required for production)
# For Vercel deployment, use Vercel Postgres, Neon, or Supabase
DATABASE_URL="postgresql://user:password@localhost:5432/pickuplocker?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/pickuplocker?schema=public"

# Bestwond Locker API (get from https://bestwond.apifox.cn/)
BESTWOND_APP_ID="your_app_id"
BESTWOND_APP_SECRET="your_app_secret"
BESTWOND_DEVICE_ID="your_device_id"
BESTWOND_BASE_URL="https://api.bestwond.com"

# DimePay Integration
DIMEPAY_API_KEY="your_dimepay_api_key"
DIMEPAY_MERCHANT_ID="your_merchant_id"
DIMEPAY_WEBHOOK_SECRET="your_webhook_secret"

# TextBee SMS Gateway
TEXTBEE_API_KEY="your_textbee_api_key"
TEXTBEE_DEVICE_ID="your_textbee_device_id"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
EMAIL_FROM="noreply@yourdomain.com"

# NextAuth.js
NEXTAUTH_SECRET="generate_with_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"
